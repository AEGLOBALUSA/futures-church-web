{
  "_meta": {
    "purpose": "Real people from every Futures campus shown on /plan-a-visit below the pastor intro. Click a face to expand their story (once filled in by comms).",
    "schemaVersion": 2,
    "placeholderStrategy": "Until campus comms captures real congregation portraits with signed releases, each campus is seeded with 6 placeholder entries pointing at real Futures photography from /photos/voices/. Placeholders render photo-only (no fabricated name/age/story). When comms swaps a placeholder to a real person, they fill first_name / age_bracket / alt_text / one_liner / longer_story and flip release_signed: true + is_placeholder: false. The card auto-unlocks full story mode.",
    "gatingRules": "Render rules in <FaceCard />: (a) if is_placeholder === true, render photo + generic 'member of Futures X family' label, no click, no age, no story; (b) if is_placeholder === false AND release_signed === true, render full card with expand; (c) any other combination → component returns null silently (never leak an unsigned real person).",
    "noFabrication": "No invented names. No invented ages. No invented stories. Placeholders stay blank on those fields until a real person signs the release.",
    "rotation": "Deterministic monthly — FNV seed on (campus_slug + YYYY-MM) picks which 6 of the available pool show per campus. Repeat visitors see different faces month to month. Server-side; no client bundle cost.",
    "targets": {
      "launch": "6 faces per campus × 13 campuses = 78 faces total",
      "month1": "12 faces per campus × 13 campuses = 156 faces",
      "fullRoster": "~252 faces once Indonesia + South America ~8 campuses are added"
    },
    "futurosLocale": "Faces under futuros-* campuses render one_liner and longer_story in Spanish. Component reads locale from campus record, not face record.",
    "slugAliases": {
      "city": "adelaide-city — routing uses 'adelaide-city'; 'city' is the brief's preferred short name, supported via alias in the loader",
      "kadina": "copper-coast — routing uses 'copper-coast'; 'kadina' is the brief's preferred short name, supported via alias in the loader"
    }
  },
