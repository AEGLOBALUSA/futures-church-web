# ─────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# ─────────────────────────────────────────────────────────────────────────
# AI
# ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://futures.church
NEXT_PUBLIC_DEFAULT_REGION=us

# ─────────────────────────────────────────────────────────────────────────
# Integrations
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BIBLE_APP_URL=https://bible.com
NEXT_PUBLIC_SELAH_APP_URL=https://selah.app
NEXT_PUBLIC_GIVE_URL=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=futures.church

# ─────────────────────────────────────────────────────────────────────────
# Campus intake portal (/intake/admin)
# ─────────────────────────────────────────────────────────────────────────
# Single shared password for the admin dashboard. Pick something memorable
# the 2–3 admins can share — pastors don't see this.
INTAKE_ADMIN_PASSWORD=
# HMAC key for signing admin session cookies. Generate with:
#   openssl rand -hex 32
# Reuses NEXTAUTH_SECRET if INTAKE_ADMIN_SECRET is unset.
INTAKE_ADMIN_SECRET=
